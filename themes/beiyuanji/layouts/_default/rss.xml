{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ if eq .Title site.Title }}{{ site.Title }}{{ else }}{{ with .Title }}{{ . }} | {{ end }}{{ site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ with site.Params.description }}{{ . }}{{ else }}{{ site.Title }}{{ end }}</description>
    <generator>Hugo -- gohugo.io</generator>
    <language>zh-CN</language>
    <lastBuildDate>{{ now.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</lastBuildDate>
    {{ with .OutputFormats.Get "RSS" }}
      {{- printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{ end }}
    {{- $pages := .RegularPages }}
    {{- if .IsHome }}
      {{- $pages = where site.RegularPages "Type" "ne" "page" }}
    {{- end }}
    {{ range first 30 $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ with .Params.summary }}{{ . | html }}{{ else }}{{ .Summary | html }}{{ end }}</description>
      {{ with .Content }}<content:encoded xmlns:content="http://purl.org/rss/1.0/modules/content/">{{ printf "<![CDATA[%s]]>" . | safeHTML }}</content:encoded>{{ end }}
    </item>
    {{ end }}
  </channel>
</rss>
